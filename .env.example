# NetMon Environment Configuration
# Copy this file to .env and edit values

# ── Database ───────────────────────────────────────────────────────
DB_USER=netmon
DB_PASSWORD=netmon_secret_change_me
DB_NAME=netmon
DB_PORT=5432

# ── API ────────────────────────────────────────────────────────────
API_PORT=8000
SECRET_KEY=change_me_use_openssl_rand_hex_32

# ── Poller Intervals (seconds) ─────────────────────────────────────
SNMP_POLL_INTERVAL=60
ESXI_POLL_INTERVAL=120

# ── Telegram Notifications ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email (SMTP) Notifications ─────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=netmon@local
